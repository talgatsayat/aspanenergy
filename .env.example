# Copy to ".env" (or export in your shell) and fill in the keys you have.
# The engine runs without any keys (MOCK extraction, manual roof area).

# --- Bill extraction (choose ONE provider) ---
# Anthropic Claude (recommended for French scanned bills)
ANTHROPIC_API_KEY=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
ANTHROPIC_MODEL=claude-sonnet-4-6

# OR OpenAI GPT
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Force a specific extractor: anthropic | openai | manual
# (manual = no extraction, empty rows for hand entry; never fabricates numbers)
ASPAN_EXTRACTOR=anthropic

# --- Geolocation / satellite preview (optional) ---
# Enables address geocoding + a Google satellite image of the site.
GOOGLE_MAPS_API_KEY=
